+    private static IEnumerable<object> FindViewModels(DependencyObject root, string viewModelTypeName)
+    {
+        var visited = new HashSet<DependencyObject>();
+        var stack = new Stack<DependencyObject>();
+        stack.Push(root);
+
+        while (stack.Count > 0)
+        {
+            var current = stack.Pop();
+            if (!visited.Add(current))
+            {
+                continue;
+            }
+
+            if (TryGetViewModel(current, viewModelTypeName, out var viewModel))
+            {
+                yield return viewModel;
+            }
+
+            foreach (var child in GetChildren(current))
+            {
+                stack.Push(child);
+            }
+        }
+    }
