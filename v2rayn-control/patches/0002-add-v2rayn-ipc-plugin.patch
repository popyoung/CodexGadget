+    private static int UpdateProfilesViewModels(DependencyObject root, SpeedTestResult result)
+    {
+        var updated = 0;
+        var visited = new HashSet<DependencyObject>();
+        var stack = new Stack<DependencyObject>();
+        stack.Push(root);
+
+        while (stack.Count > 0)
+        {
+            var current = stack.Pop();
+            if (!visited.Add(current))
+            {
+                continue;
+            }
+
+            if (TryGetViewModel(current, "ServiceLib.ViewModels.ProfilesViewModel", out var viewModel)
+                && TrySetSpeedTestResult(viewModel, result))
+            {
+                updated++;
+            }
+
+            foreach (var child in GetChildren(current))
+            {
+                stack.Push(child);
+            }
+        }
+
+        return updated;
+    }
+
+    private static bool TryGetViewModel(DependencyObject current, string viewModelTypeName, out object viewModel)
+    {
+        viewModel = null!;
+
+        if (current is FrameworkElement { DataContext: { } dataContext }
+            && IsViewModel(dataContext, viewModelTypeName))
+        {
+            viewModel = dataContext;
+            return true;
+        }
+
+        var property = current.GetType().GetProperty(
+            "ViewModel",
+            BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);
+        var value = property?.GetValue(current);
+        if (!IsViewModel(value, viewModelTypeName))
+        {
+            return false;
+        }
+
+        viewModel = value!;
+        return true;
+    }
+
+    private static bool IsViewModel(object? value, string viewModelTypeName)
+    {
+        return string.Equals(
+            value?.GetType().FullName,
+            viewModelTypeName,
+            StringComparison.Ordinal);
+    }
+
+    private static bool TrySetSpeedTestResult(object viewModel, SpeedTestResult result)
+    {
+        var method = viewModel.GetType()
+            .GetMethods(BindingFlags.Instance | BindingFlags.Public)
+            .FirstOrDefault(t => t.Name == "SetSpeedTestResult"
+                                 && t.GetParameters() is [{ }]);
+        if (method is null)
+        {
+            return false;
+        }
+
+        var parameterType = method.GetParameters()[0].ParameterType;
+        var hostResult = BuildHostSpeedTestResult(parameterType, result);
+        if (hostResult is null)
+        {
+            return false;
+        }
+
+        var invokeResult = method.Invoke(viewModel, [hostResult]);
+        if (invokeResult is Task task)
+        {
+            _ = task;
+        }
+
+        return true;
+    }
+
+    private static object? BuildHostSpeedTestResult(Type parameterType, SpeedTestResult result)
+    {
+        if (parameterType.IsInstanceOfType(result))
+        {
+            return result;
+        }
+
+        var hostResult = Activator.CreateInstance(parameterType);
+        if (hostResult is null)
+        {
+            return null;
+        }
+
+        parameterType.GetProperty("IndexId")?.SetValue(hostResult, result.IndexId);
+        parameterType.GetProperty("Delay")?.SetValue(hostResult, result.Delay);
+        parameterType.GetProperty("Speed")?.SetValue(hostResult, result.Speed);
+        return hostResult;
+    }
