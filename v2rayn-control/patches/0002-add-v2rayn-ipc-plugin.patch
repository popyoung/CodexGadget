+    private static void UpdateProfilesView(SpeedTestResult result)
+    {
+        try
+        {
+            var application = Application.Current;
+            var dispatcher = application?.Dispatcher;
+            if (application is null || dispatcher is null)
+            {
+                return;
+            }
+
+            dispatcher.BeginInvoke(new Action(() =>
+            {
+                try
+                {
+                    var updated = 0;
+                    foreach (Window window in application.Windows)
+                    {
+                        updated += UpdateProfilesViewModels(window, result);
+                    }
+
+                    Logging.SaveLog($"V2rayNIpcPlugin updated {updated} ProfilesViewModel instance(s).");
+                }
+                catch (Exception ex)
+                {
+                    Logging.SaveLog("V2rayNIpcPlugin UpdateProfilesView", ex);
+                }
+            }));
+        }
+        catch (Exception ex)
+        {
+            Logging.SaveLog("V2rayNIpcPlugin UpdateProfilesView", ex);
+        }
+    }
