+    private static string EnsureCidr(string address)
+    {
+        if (address.Contains('/'))
+        {
+            return address;
+        }
+
+        if (System.Net.IPAddress.TryParse(address, out var ip))
+        {
+            return ip.AddressFamily == System.Net.Sockets.AddressFamily.InterNetworkV6
+                ? $"{address}/128"
+                : $"{address}/32";
+        }
+
+        return address;
+    }
