+        var networks = SplitRoutingValues(item.Network);
+        if (networks.Count > 0)
+        {
+            rule.Network = networks;
+        }
+
+        if (item.Protocol?.Count > 0)
+        {
+            rule.Protocol = item.Protocol
+                .Select(t => t?.Trim())
+                .Where(t => t.IsNotEmpty())
+                .ToList()!;
