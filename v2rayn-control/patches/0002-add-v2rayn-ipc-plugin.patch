+            methodName,
+            BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic,
+            null,
+            [],
+            null);
+        if (method is null)
+        {
+            return false;
+        }
+
+        var result = method.Invoke(target, []);
+        if (result is Task task)
+        {
+            _ = task;
+        }
+
+        return true;
+    }
