+using System.Collections.Concurrent;
+using System.IO;
+using System.IO.Pipes;
+using System.Reflection;
+using System.Security.AccessControl;
+using System.Security.Principal;
+using System.Text;
+using System.Text.Encodings.Web;
+using System.Text.Json;
+using System.Text.Json.Serialization;
+using System.Windows;
+using System.Windows.Media;
+using ServiceLib;
+using ServiceLib.Common;
+using ServiceLib.Enums;
+using ServiceLib.Handler;
+using ServiceLib.Manager;
+using ServiceLib.Models;
+using ServiceLib.Plugins;
+using ServiceLib.Resx;
+using ServiceLib.Services;
+
+namespace V2rayN.IpcPlugin;
+
+public sealed class V2rayNIpcPlugin : IV2rayNPlugin
+{
+    private const string PipeName = "v2rayn-control";
+    private static readonly JsonSerializerOptions JsonOptions = new()
+    {
+        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
+        DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull,
+        Encoder = JavaScriptEncoder.UnsafeRelaxedJsonEscaping
+    };
+
+    private static readonly JsonSerializerOptions PrettyJsonOptions = new()
+    {
+        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
+        DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull,
+        Encoder = JavaScriptEncoder.UnsafeRelaxedJsonEscaping,
+        WriteIndented = true
+    };
+
+    private readonly ConcurrentDictionary<string, SpeedTestResult> _testUpdates = new();
+    private readonly object _syncRoot = new();
+    private CancellationTokenSource? _cts;
+    private Task? _acceptTask;
+    private Config? _config;
+    private SpeedtestService? _speedtestService;
+
+    public string Name => "v2rayn-ipc";
+
+    public Task Start(V2rayNPluginContext context, CancellationToken token)
+    {
+        lock (_syncRoot)
+        {
+            if (_cts is not null)
+            {
+                return Task.CompletedTask;
+            }
+
+            _config = context.Config;
+            _speedtestService = new SpeedtestService(_config, OnSpeedTestUpdate);
+            _cts = CancellationTokenSource.CreateLinkedTokenSource(token);
+            _acceptTask = Task.Run(() => AcceptLoop(_cts.Token), CancellationToken.None);
+        }
+
+        return Task.CompletedTask;
+    }
+
+    public async Task Stop()
+    {
+        Task? acceptTask;
+        lock (_syncRoot)
+        {
+            _cts?.Cancel();
+            acceptTask = _acceptTask;
+        }
+
+        if (acceptTask is not null)
+        {
+            await Task.WhenAny(acceptTask, Task.Delay(1000));
+        }
+
+        lock (_syncRoot)
+        {
+            _cts?.Dispose();
+            _cts = null;
+            _acceptTask = null;
+        }
+    }
+
+    public async ValueTask DisposeAsync()
+    {
+        await Stop();
+    }
+
+    private async Task AcceptLoop(CancellationToken token)
+    {
+        while (!token.IsCancellationRequested)
+        {
+            NamedPipeServerStream? pipe = null;
+            try
+            {
+                pipe = NamedPipeServerStreamAcl.Create(
+                    PipeName,
+                    PipeDirection.InOut,
+                    NamedPipeServerStream.MaxAllowedServerInstances,
+                    PipeTransmissionMode.Byte,
+                    PipeOptions.Asynchronous,
+                    8192,
+                    8192,
+                    CreatePipeSecurity());
+                await pipe.WaitForConnectionAsync(token);
+                var connectedPipe = pipe;
+                pipe = null;
+                _ = Task.Run(() => HandleClient(connectedPipe, token), CancellationToken.None);
+            }
+            catch (OperationCanceledException)
+            {
+                pipe?.Dispose();
+                return;
+            }
+            catch (Exception ex)
+            {
+                pipe?.Dispose();
+                Logging.SaveLog("V2rayNIpcPlugin AcceptLoop", ex);
+                await Task.Delay(1000, token).ContinueWith(_ => { }, TaskScheduler.Default);
+            }
+        }
+    }
+
+    private async Task HandleClient(NamedPipeServerStream pipe, CancellationToken token)
+    {
+        await using var pipeScope = pipe;
+        using var reader = new StreamReader(pipeScope, Encoding.UTF8, false, 8192, true);
+        await using var writer = new StreamWriter(pipeScope, new UTF8Encoding(false), 8192, true)
+        {
+            AutoFlush = true
+        };
+
+        while (pipeScope.IsConnected && !token.IsCancellationRequested)
+        {
+            var line = await reader.ReadLineAsync();
+            if (line is null)
+            {
+                break;
+            }
+
+            object response;
+            try
+            {
+                response = await HandleRequest(line);
+            }
+            catch (Exception ex)
+            {
+                Logging.SaveLog("V2rayNIpcPlugin HandleRequest", ex);
+                response = Error("internal_error", ex.Message);
+            }
+
+            await writer.WriteLineAsync(JsonSerializer.Serialize(response, JsonOptions));
+        }
+    }
+
+    private async Task<object> HandleRequest(string requestLine)
+    {
+        using var doc = JsonDocument.Parse(requestLine);
+        var root = doc.RootElement;
+        var cmd = GetString(root, "cmd")?.Trim().ToLowerInvariant();
+
+        return cmd switch
+        {
+            "ping" => Ok(new
+            {
+                pipe = PipeName,
+                plugin = Name,
+                version = "5",
+                appVersion = Utils.GetVersion(false),
+                currentIndexId = _config?.IndexId
+            }),
+            "list" => Ok(new
+            {
+                currentIndexId = _config?.IndexId,
+                nodes = await BuildNodeList(root)
+            }),
+            "switch" => await SwitchNode(root),
+            "reload" => ReloadPlugin(),
+            "test" => await StartSpeedTest(root),
+            "test-stop" => StopSpeedTest(),
+            "test-status" => Ok(new { updates = _testUpdates.Values.OrderBy(t => t.IndexId).ToList() }),
+            "export-karing" or "karing-export" => await ExportKaring(root),
+            _ => Error("unknown_command", $"Unknown command: {cmd}")
+        };
+    }
+
+    private async Task<List<NodeModel>> BuildNodeList(JsonElement request)
+    {
+        var group = GetString(request, "group");
+        var filter = GetString(request, "filter") ?? string.Empty;
+        var profiles = await AppManager.Instance.ProfileModels("", filter) ?? [];
+        var profileExs = await ProfileExManager.Instance.GetProfileExs();
+        var exById = profileExs.ToDictionary(t => t.IndexId, t => t);
+
+        if (group.IsNotEmpty())
+        {
+            profiles = profiles
+                .Where(t => string.Equals(t.SubRemarks, group, StringComparison.OrdinalIgnoreCase)
+                            || string.Equals(t.Subid, group, StringComparison.OrdinalIgnoreCase))
+                .ToList();
+        }
+
+        var ordered = profiles
+            .Select((profile, index) => new
+            {
+                Profile = profile,
+                OriginalIndex = index,
+                Ex = exById.GetValueOrDefault(profile.IndexId)
+            })
+            .OrderBy(t => t.Ex?.Sort ?? 0)
+            .ThenBy(t => t.OriginalIndex)
+            .ToList();
+
+        return ordered
+            .Select((item, index) => new NodeModel
+            {
+                Number = index + 1,
+                IndexId = item.Profile.IndexId,
+                Name = item.Profile.Remarks,
+                Group = item.Profile.SubRemarks,
+                GroupId = item.Profile.Subid,
+                Type = item.Profile.ConfigType.ToString(),
+                Address = item.Profile.Address,
+                Port = item.Profile.Port,
+                Delay = item.Ex?.Delay ?? 0,
+                Speed = item.Ex?.Speed ?? 0,
+                SpeedMessage = item.Ex?.Message ?? string.Empty,
+                Current = item.Profile.IndexId == _config?.IndexId
+            })
+            .ToList();
+    }
+
+    private async Task<object> SwitchNode(JsonElement request)
+    {
+        if (_config is null)
+        {
+            return Error("not_ready", "v2rayN config is not initialized.");
+        }
+
+        var node = await ResolveSingleNode(request);
+        if (node is null)
+        {
+            return Error("node_not_found", "Could not resolve a node from number or indexId.");
+        }
+
+        if (await ConfigHandler.SetDefaultServerIndex(_config, node.IndexId) != 0)
+        {
+            return Error("switch_failed", $"Failed to set default server: {node.IndexId}");
+        }
+
+        ScheduleReload();
+
+        return Ok(new
+        {
+            switched = true,
+            node.Number,
+            node.IndexId,
+            node.Name,
+            node.Group
+        });
+    }
+
+    private object ReloadPlugin()
+    {
+        SchedulePluginReload();
+        return Ok(new
+        {
+            pluginsReloaded = true,
+            currentIndexId = _config?.IndexId
+        });
+    }
+
+    private async Task<object> StartSpeedTest(JsonElement request)
+    {
+        if (_config is null || _speedtestService is null)
+        {
+            return Error("not_ready", "v2rayN speed test service is not initialized.");
+        }
+
+        var action = ParseSpeedAction(GetString(request, "action"));
+        var nodes = await ResolveNodes(request, defaultToCurrent: true);
+        if (nodes.Count == 0)
+        {
+            return Error("node_not_found", "No testable nodes were resolved.");
+        }
+
+        var profiles = await AppManager.Instance.GetProfileItemsByIndexIds(nodes.Select(t => t.IndexId));
+        var orderedProfiles = nodes
+            .Select(t => profiles.FirstOrDefault(p => p.IndexId == t.IndexId))
+            .Where(t => t is not null)
+            .ToList();
+
+        if (orderedProfiles.Count == 0)
+        {
+            return Error("node_not_found", "No profile records were found for the selected nodes.");
+        }
+
+        foreach (var node in nodes)
+        {
+            _testUpdates.TryRemove(node.IndexId, out _);
+        }
+
+        _speedtestService.RunLoop(action, orderedProfiles);
+
+        return Ok(new
+        {
+            started = true,
+            action = action.ToString(),
+            count = orderedProfiles.Count,
+            nodes = nodes.Select(t => new { t.Number, t.IndexId, t.Name, t.Group }).ToList()
+        });
+    }
+
+    private object StopSpeedTest()
+    {
+        _speedtestService?.ExitLoop();
+        return Ok(new { stopped = true });
+    }
+
+    private async Task<object> ExportKaring(JsonElement request)
+    {
+        if (_config is null)
+        {
+            return Error("not_ready", "v2rayN config is not initialized.");
+        }
+
+        var routing = await ConfigHandler.GetDefaultRouting(_config);
+        if (routing is null)
+        {
+            return Error("routing_not_found", "Could not resolve the current routing item.");
+        }
+
+        var rules = JsonUtils.Deserialize<List<RulesItem>>(routing.RuleSet) ?? [];
+        var warnings = new List<string>();
+        var karingDoc = new KaringCustomRulesDocument();
+        var singboxRules = new List<Rule4Sbox>();
+
+        var disabledCount = 0;
+        var dnsCount = 0;
+        var exportedRoutingCount = 0;
+
+        for (var i = 0; i < rules.Count; i++)
+        {
+            var item = rules[i];
+            if (!item.Enabled)
+            {
+                disabledCount++;
+                continue;
+            }
+
+            if (item.RuleType == ERuleType.DNS)
+            {
+                dnsCount++;
+                continue;
+            }
+
+            exportedRoutingCount++;
+            var ruleName = GetRuleName(item, i + 1);
+            var karingRule = BuildKaringRule(item, ruleName, warnings);
+            if (karingRule is not null)
+            {
+                karingDoc.Rules.Add(karingRule);
+            }
+
+            singboxRules.AddRange(BuildSingboxRules(item, ruleName, warnings));
+        }
+
+        var outputDir = ResolveKaringOutputDir(request, routing);
+        Directory.CreateDirectory(outputDir);
+
+        var karingPath = Path.Combine(outputDir, "diversion_rules_custom.json");
+        var singboxPath = Path.Combine(outputDir, "v2rayn-singbox-route.json");
+        var rawPath = Path.Combine(outputDir, "v2rayn-routing-raw.json");
+
+        await WriteJsonFile(karingPath, karingDoc);
+        await WriteJsonFile(singboxPath, new
+        {
+            route = new
+            {
+                rules = singboxRules,
+                final = Global.ProxyTag,
+                domainStrategy = routing.DomainStrategy4Singbox.IsNotEmpty()
+                    ? routing.DomainStrategy4Singbox
+                    : routing.DomainStrategy
+            }
+        });
+        await WriteJsonFile(rawPath, new
+        {
+            routing = new
+            {
+                routing.Id,
+                routing.Remarks,
+                routing.Enabled,
+                routing.DomainStrategy,
+                routing.DomainStrategy4Singbox,
+                routing.RuleNum
+            },
+            rules
+        });
+
+        return Ok(new
+        {
+            routing = new
+            {
+                routing.Id,
+                routing.Remarks,
+                ruleCount = rules.Count,
+                exportedRoutingCount,
+                disabledCount,
+                dnsCount
+            },
+            karingRules = karingDoc.Rules.Count,
+            singboxRules = singboxRules.Count,
+            files = new
+            {
+                karing = karingPath,
+                singboxRoute = singboxPath,
+                raw = rawPath
+            },
+            warnings
+        });
+    }
+
+    private async Task<NodeModel?> ResolveSingleNode(JsonElement request)
+    {
+        var nodes = await ResolveNodes(request, defaultToCurrent: false);
+        return nodes.FirstOrDefault();
+    }
+
+    private async Task<List<NodeModel>> ResolveNodes(JsonElement request, bool defaultToCurrent)
+    {
+        var nodes = await BuildNodeList(request);
+        var ids = GetStringArray(request, "indexIds");
+        var singleId = GetString(request, "indexId");
+        if (singleId.IsNotEmpty())
+        {
+            ids.Add(singleId);
+        }
+
+        var numbers = GetIntArray(request, "numbers");
+        if (TryGetInt(request, "number", out var singleNumber))
+        {
+            numbers.Add(singleNumber);
+        }
+
+        if (ids.Count > 0)
+        {
+            return ids
+                .Select(id => nodes.FirstOrDefault(t => t.IndexId == id))
+                .Where(t => t is not null)
+                .ToList();
+        }
+
+        if (numbers.Count > 0)
+        {
+            return numbers
+                .Select(number => nodes.FirstOrDefault(t => t.Number == number))
+                .Where(t => t is not null)
+                .ToList();
+        }
+
+        if (GetString(request, "group").IsNotEmpty() || GetString(request, "filter").IsNotEmpty())
+        {
+            return nodes;
+        }
+
+        if (defaultToCurrent && _config?.IndexId.IsNotEmpty() == true)
+        {
+            var current = nodes.FirstOrDefault(t => t.IndexId == _config.IndexId);
+            return current is null ? [] : [current];
+        }
+
+        return [];
+    }
+
+    private static ESpeedActionType ParseSpeedAction(string? action)
+    {
+        return (action ?? "realping").Trim().ToLowerInvariant() switch
+        {
+            "tcp" or "tcping" => ESpeedActionType.Tcping,
+            "real" or "realping" or "ping" => ESpeedActionType.Realping,
+            "udp" or "udptest" => ESpeedActionType.UdpTest,
+            "speed" or "speedtest" => ESpeedActionType.Speedtest,
+            "mixed" or "mixedtest" => ESpeedActionType.Mixedtest,
+            _ => ESpeedActionType.Realping
+        };
+    }
+
+    private static string ResolveKaringOutputDir(JsonElement request, RoutingItem routing)
+    {
+        var outputDir = GetString(request, "outputDir") ?? GetString(request, "path");
+        if (outputDir.IsNotEmpty())
+        {
+            return Path.GetFullPath(Environment.ExpandEnvironmentVariables(outputDir!));
+        }
+
+        var safeRemarks = SanitizeFileName(routing.Remarks);
+        var dirName = $"{DateTime.Now:yyyyMMdd-HHmmss}-{safeRemarks}".TrimEnd('-');
+        return Path.Combine(Utils.StartupPath(), "exports", "karing", dirName);
+    }
+
+    private static async Task WriteJsonFile(string path, object value)
+    {
+        var json = JsonSerializer.Serialize(value, PrettyJsonOptions);
+        await File.WriteAllTextAsync(path, json + Environment.NewLine, new UTF8Encoding(false));
+    }
+
+    private static KaringCustomRule? BuildKaringRule(RulesItem item, string ruleName, List<string> warnings)
+    {
+        var rule = new KaringCustomRule
+        {
+            Name = ruleName,
+            Outbound = MapKaringOutbound(item.OutboundTag, ruleName, warnings),
+            Switch = true,
+            Or = true
+        };
+
+        FillKaringBaseConditions(item, rule, ruleName, warnings);
+
+        if (item.Domain?.Count > 0)
+        {
+            foreach (var domain in item.Domain)
+            {
+                ParseKaringDomain(domain, rule, ruleName, warnings);
+            }
+        }
+
+        if (item.Ip?.Count > 0)
+        {
+            foreach (var address in item.Ip)
+            {
+                ParseKaringAddress(address, rule, ruleName, warnings);
+            }
+        }
+
+        if (item.Process?.Count > 0)
+        {
+            warnings.Add($"Rule `{ruleName}` contains process matching; it may not be useful on Android Karing.");
+            foreach (var process in item.Process.Select(t => t?.Trim()).Where(t => t.IsNotEmpty()))
+            {
+                if (process!.Contains('/') || process.Contains('\\'))
+                {
+                    rule.ProcessPath ??= [];
+                    rule.ProcessPath.Add(process);
+                }
+                else
+                {
+                    rule.ProcessName ??= [];
+                    rule.ProcessName.Add(Utils.GetExeName(process));
+                }
+            }
+        }
+
+        if (item.InboundTag?.Count > 0)
+        {
+            warnings.Add($"Rule `{ruleName}` contains inboundTag, which is not exported to Karing custom diversion rules.");
+        }
+
+        if (!HasKaringCriteria(rule))
+        {
+            warnings.Add($"Rule `{ruleName}` has no portable Karing criteria and was skipped in diversion_rules_custom.json.");
+            return null;
+        }
+
+        NormalizeKaringRule(rule);
+        return rule;
+    }
+
+    private static List<Rule4Sbox> BuildSingboxRules(RulesItem item, string ruleName, List<string> warnings)
+    {
+        var result = new List<Rule4Sbox>();
+        var rule = new Rule4Sbox();
+        var outbound = item.OutboundTag ?? Global.ProxyTag;
+        if (string.Equals(outbound, Global.BlockTag, StringComparison.OrdinalIgnoreCase))
+        {
+            rule.action = "reject";
+        }
+        else
+        {
+            rule.outbound = MapSingboxOutbound(outbound, ruleName, warnings);
+        }
+
+        FillSingboxBaseConditions(item, rule, ruleName, warnings);
+
+        var hasSpecificCriteria = false;
+        if (item.Domain?.Count > 0)
+        {
+            var domainRule = JsonUtils.DeepCopy(rule) ?? new Rule4Sbox();
+            var count = 0;
+            foreach (var domain in item.Domain)
+            {
+                if (ParseSingboxDomain(domain, domainRule, ruleName, warnings))
+                {
+                    count++;
+                }
+            }
+
+            if (count > 0)
+            {
+                result.Add(domainRule);
+                hasSpecificCriteria = true;
+            }
+        }
+
+        if (item.Ip?.Count > 0)
+        {
+            var ipRule = JsonUtils.DeepCopy(rule) ?? new Rule4Sbox();
+            var count = 0;
+            var negativeIpList = item.Ip
+                .Where(t => t.IsNotEmpty() && t!.TrimStart().StartsWith('!'))
+                .ToList();
+
+            if (negativeIpList.Count > 0)
+            {
+                var positiveIpList = item.Ip.Except(negativeIpList).ToList();
+                var positiveRule = JsonUtils.DeepCopy(ipRule) ?? new Rule4Sbox();
+                positiveRule.outbound = null;
+                positiveRule.action = null;
+                foreach (var address in positiveIpList)
+                {
+                    if (ParseSingboxAddress(address, positiveRule, ruleName, warnings))
+                    {
+                        count++;
+                    }
+                }
+
+                var negativeRule = new Rule4Sbox();
+                foreach (var address in negativeIpList)
+                {
+                    var normalizedAddress = address.TrimStart()[1..].Trim();
+                    if (ParseSingboxAddress(normalizedAddress, negativeRule, ruleName, warnings))
+                    {
+                        count++;
+                    }
+                }
+
+                negativeRule.invert = true;
+                ipRule = new Rule4Sbox
+                {
+                    outbound = ipRule.outbound,
+                    action = ipRule.action,
+                    type = "logical",
+                    mode = "or",
+                    rules = []
+                };
+                if (HasSingboxCriteria(positiveRule))
+                {
+                    ipRule.rules.Add(positiveRule);
+                }
+                if (HasSingboxCriteria(negativeRule))
+                {
+                    ipRule.rules.Add(negativeRule);
+                }
+            }
+            else
+            {
+                foreach (var address in item.Ip)
+                {
+                    if (ParseSingboxAddress(address, ipRule, ruleName, warnings))
+                    {
+                        count++;
+                    }
+                }
+            }
+
+            if (count > 0)
+            {
+                result.Add(ipRule);
+                hasSpecificCriteria = true;
+            }
+        }
+
+        if (item.Process?.Count > 0)
+        {
+            var processNameRule = JsonUtils.DeepCopy(rule) ?? new Rule4Sbox();
+            processNameRule.process_name ??= [];
+            var processPathRule = JsonUtils.DeepCopy(rule) ?? new Rule4Sbox();
+            processPathRule.process_path ??= [];
+
+            foreach (var process in item.Process.Select(t => t?.Trim()).Where(t => t.IsNotEmpty()))
+            {
+                if (process is "self/" or "xray/")
+                {
+                    processNameRule.process_name.Add(Utils.GetExeName("sing-box"));
+                    continue;
+                }
+
+                if (process!.Contains('/') || process.Contains('\\'))
+                {
+                    processPathRule.process_path.Add(process);
+                    continue;
+                }
+
+                processNameRule.process_name.Add(Utils.GetExeName(process));
+            }
+
+            if (processNameRule.process_name.Count > 0)
+            {
+                result.Add(processNameRule);
+                hasSpecificCriteria = true;
+            }
+
+            if (processPathRule.process_path.Count > 0)
+            {
+                result.Add(processPathRule);
+                hasSpecificCriteria = true;
+            }
+        }
+
+        if (!hasSpecificCriteria && HasSingboxCriteria(rule))
+        {
+            result.Add(rule);
+        }
+
+        return result;
+    }
+
+    private static void FillKaringBaseConditions(RulesItem item, KaringCustomRule rule, string ruleName, List<string> warnings)
+    {
+        if (item.Port.IsNotEmpty())
+        {
+            foreach (var port in SplitRoutingValues(item.Port))
+            {
