diff --git a/v2rayN/ServiceLib/Plugins/V2rayNPluginLoadContext.cs b/v2rayN/ServiceLib/Plugins/V2rayNPluginLoadContext.cs
new file mode 100644
index 0000000..74d991b
--- /dev/null
+++ b/v2rayN/ServiceLib/Plugins/V2rayNPluginLoadContext.cs
@@ -0,0 +1,25 @@
+using System.Runtime.Loader;
+
+namespace ServiceLib.Plugins;
+
+internal sealed class V2rayNPluginLoadContext(string pluginPath) : AssemblyLoadContext(isCollectible: true)
+{
+    private readonly AssemblyDependencyResolver _resolver = new(pluginPath);
+
+    protected override Assembly? Load(AssemblyName assemblyName)
+    {
+        if (assemblyName.Name == typeof(IV2rayNPlugin).Assembly.GetName().Name)
+        {
+            return null;
+        }
+
+        var assemblyPath = _resolver.ResolveAssemblyToPath(assemblyName);
+        return assemblyPath is null ? null : LoadFromAssemblyPath(assemblyPath);
+    }
+
+    protected override nint LoadUnmanagedDll(string unmanagedDllName)
+    {
+        var libraryPath = _resolver.ResolveUnmanagedDllToPath(unmanagedDllName);
+        return libraryPath is null ? nint.Zero : LoadUnmanagedDllFromPath(libraryPath);
+    }
+}
diff --git a/v2rayN/ServiceLib/Plugins/V2rayNPluginManager.cs b/v2rayN/ServiceLib/Plugins/V2rayNPluginManager.cs
new file mode 100644
index 0000000..1387a63
--- /dev/null
+++ b/v2rayN/ServiceLib/Plugins/V2rayNPluginManager.cs
@@ -0,0 +1,193 @@
+namespace ServiceLib.Plugins;
+
+public sealed class V2rayNPluginManager
+{
+    private sealed class LoadedPlugin
+    {
+        public string Path { get; init; }
+        public string ShadowPath { get; init; }
+        public IV2rayNPlugin Plugin { get; init; }
+        public V2rayNPluginLoadContext LoadContext { get; init; }
+        public CancellationTokenSource Cancellation { get; init; }
+    }
+
+    private static readonly Lazy<V2rayNPluginManager> LazyInstance = new(() => new());
+    private readonly SemaphoreSlim _reloadSemaphore = new(1, 1);
+    private readonly List<LoadedPlugin> _plugins = [];
+    private static readonly string _tag = "V2rayNPluginManager";
+
+    public static V2rayNPluginManager Instance => LazyInstance.Value;
+
+    public async Task Reload(Config config)
+    {
+        await _reloadSemaphore.WaitAsync().ConfigureAwait(false);
+        try
+        {
+            await StopAllInternal().ConfigureAwait(false);
+            await LoadAll(config).ConfigureAwait(false);
+        }
+        finally
+        {
+            _reloadSemaphore.Release();
+        }
+    }
+
+    public async Task StopAll()
+    {
+        await _reloadSemaphore.WaitAsync().ConfigureAwait(false);
+        try
+        {
+            await StopAllInternal().ConfigureAwait(false);
+        }
+        finally
+        {
+            _reloadSemaphore.Release();
+        }
+    }
+
+    private async Task LoadAll(Config config)
+    {
+        var pluginDir = Path.Combine(Utils.StartupPath(), "guiPlugins");
+        Directory.CreateDirectory(pluginDir);
+
+        foreach (var pluginPath in Directory.EnumerateFiles(pluginDir, "*.dll", SearchOption.TopDirectoryOnly)
+                     .Where(IsPluginCandidate))
+        {
+            await LoadOne(config, pluginPath).ConfigureAwait(false);
+        }
+    }
+
+    private async Task LoadOne(Config config, string pluginPath)
+    {
+        var shadowPath = ShadowCopy(pluginPath);
+        var loadContext = new V2rayNPluginLoadContext(shadowPath);
+        try
+        {
+            var assembly = loadContext.LoadFromAssemblyPath(shadowPath);
+            var pluginTypes = GetLoadableTypes(assembly)
+                .Where(t => typeof(IV2rayNPlugin).IsAssignableFrom(t)
+                            && t is { IsAbstract: false, IsInterface: false }
+                            && t.GetConstructor(Type.EmptyTypes) is not null)
+                .ToList();
+            if (pluginTypes.Count == 0)
+            {
+                loadContext.Unload();
+                return;
+            }
+
+            foreach (var pluginType in pluginTypes)
+            {
+                var plugin = (IV2rayNPlugin)Activator.CreateInstance(pluginType);
+                var cancellation = new CancellationTokenSource();
+                await plugin.Start(new V2rayNPluginContext(config), cancellation.Token).ConfigureAwait(false);
+                _plugins.Add(new LoadedPlugin
+                {
+                    Path = pluginPath,
+                    ShadowPath = shadowPath,
+                    Plugin = plugin,
+                    LoadContext = loadContext,
+                    Cancellation = cancellation
+                });
+                Logging.SaveLog($"Loaded plugin {plugin.Name}: {pluginPath}");
+            }
+        }
+        catch (Exception ex)
+        {
+            Logging.SaveLog($"{_tag}: failed to load {pluginPath}", ex);
+            loadContext.Unload();
+        }
+    }
+
+    private static bool IsPluginCandidate(string pluginPath)
+    {
+        var fileName = Path.GetFileName(pluginPath);
+        return fileName.EndsWith("Plugin.dll", StringComparison.OrdinalIgnoreCase);
+    }
+
+    private static IEnumerable<Type> GetLoadableTypes(Assembly assembly)
+    {
+        try
+        {
+            return assembly.GetTypes();
+        }
+        catch (ReflectionTypeLoadException ex)
+        {
+            foreach (var loaderException in ex.LoaderExceptions.Where(t => t is not null))
+            {
+                Logging.SaveLog($"{_tag}: failed to inspect {assembly.FullName}", loaderException!);
+            }
+
+            return ex.Types.OfType<Type>();
+        }
+    }
+
+    private static string ShadowCopy(string pluginPath)
+    {
+        var pluginName = Path.GetFileNameWithoutExtension(pluginPath);
+        var sourceDir = Path.GetDirectoryName(pluginPath)!;
+        var shadowDir = Path.Combine(
+            Utils.GetTempPath("gui-plugin-cache"),
+            $"{pluginName}-{DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}-{Guid.NewGuid():N}");
+        Directory.CreateDirectory(shadowDir);
+
+        foreach (var sourcePath in Directory.EnumerateFiles(sourceDir, "*", SearchOption.TopDirectoryOnly))
+        {
+            var extension = Path.GetExtension(sourcePath);
+            if (!string.Equals(extension, ".dll", StringComparison.OrdinalIgnoreCase)
+                && !string.Equals(extension, ".json", StringComparison.OrdinalIgnoreCase)
+                && !string.Equals(extension, ".deps.json", StringComparison.OrdinalIgnoreCase)
+                && !string.Equals(extension, ".runtimeconfig.json", StringComparison.OrdinalIgnoreCase))
+            {
+                continue;
+            }
+
+            File.Copy(sourcePath, Path.Combine(shadowDir, Path.GetFileName(sourcePath)), true);
+        }
+
+        return Path.Combine(shadowDir, Path.GetFileName(pluginPath));
+    }
+
+    private async Task StopAllInternal()
+    {
+        foreach (var loaded in _plugins.ToList())
+        {
+            try
+            {
+                loaded.Cancellation.Cancel();
+                await loaded.Plugin.Stop().ConfigureAwait(false);
+                await loaded.Plugin.DisposeAsync().ConfigureAwait(false);
+            }
+            catch (Exception ex)
+            {
+                Logging.SaveLog($"{_tag}: failed to stop {loaded.Path}", ex);
+            }
+            finally
+            {
+                loaded.Cancellation.Dispose();
+                loaded.LoadContext.Unload();
+                TryDeleteShadowDirectory(loaded.ShadowPath);
+            }
+        }
+
+        _plugins.Clear();
+        GC.Collect();
+        GC.WaitForPendingFinalizers();
+        GC.Collect();
+    }
+
+    private static void TryDeleteShadowDirectory(string shadowPath)
+    {
+        try
+        {
+            var shadowDir = Path.GetDirectoryName(shadowPath);
+            if (shadowDir.IsNotEmpty() && Directory.Exists(shadowDir))
+            {
+                Directory.Delete(shadowDir, true);
+            }
+        }
+        catch
+        {
+            // The collectible AssemblyLoadContext can release files after finalization; stale cache dirs are harmless.
+        }
+    }
+}
